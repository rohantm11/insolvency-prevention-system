# Insolvency Prevention System - Environment Variables
# Copy this file to .env and configure for your environment

# =============================================================================
# Application Settings
# =============================================================================

# Environment mode: development, staging, production
NODE_ENV=production

# Docker image tag for versioning
TAG=latest

# =============================================================================
# Backend Configuration
# =============================================================================

# Backend server port (internal)
BACKEND_PORT=8000

# Log level: debug, info, warning, error
LOG_LEVEL=info

# Python settings
PYTHONDONTWRITEBYTECODE=1
PYTHONUNBUFFERED=1

# CORS allowed origins (comma-separated for multiple)
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# Database URL (if using database in future)
# DATABASE_URL=postgresql://user:password@localhost:5432/insolvency_db

# =============================================================================
# Frontend Configuration
# =============================================================================

# Frontend server port
FRONTEND_PORT=80

# API URL for frontend to connect to backend
# Use /api for production (proxied through nginx)
# Use http://localhost:8000 for local development
VITE_API_URL=/api

# =============================================================================
# ML Model Settings
# =============================================================================

# Path to trained models directory
MODEL_PATH=./ml_models/trained_models

# Model prediction threshold (0.0 - 1.0)
# PREDICTION_THRESHOLD=0.5

# =============================================================================
# Market Intelligence API Keys (Optional - enables live market research)
# =============================================================================

# NewsAPI.org - Free tier: 100 requests/day
# Get your key at: https://newsapi.org/register
NEWS_API_KEY=

# FRED (Federal Reserve Economic Data) - Free
# Get your key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Alpha Vantage - Free tier: 25 requests/day
# Get your key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# =============================================================================
# Security (Production)
# =============================================================================

# Secret key for JWT tokens (generate with: openssl rand -hex 32)
# SECRET_KEY=your-secret-key-here

# API key for external integrations (if needed)
# API_KEY=your-api-key-here

# =============================================================================
# Monitoring & Logging (Optional)
# =============================================================================

# Sentry DSN for error tracking
# SENTRY_DSN=https://your-sentry-dsn

# Enable metrics collection
# ENABLE_METRICS=true

# =============================================================================
# Cloud Deployment (Optional)
# =============================================================================

# AWS Configuration
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# Docker Registry
# DOCKER_REGISTRY=your-registry.azurecr.io
# DOCKER_USERNAME=your-username
# DOCKER_PASSWORD=your-password
